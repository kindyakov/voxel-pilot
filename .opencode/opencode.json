{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "read": {
      "D:/Developer/Minecraft_bot/.opencode/get-shit-done/*": "allow"
    },
    "external_directory": {
      "D:/Developer/Minecraft_bot/.opencode/get-shit-done/*": "allow"
    }
  },
  "mcp": {
    "serena": {
      "type": "local",
      "command": [
        "uvx",
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--project-from-cwd"
      ],
      "enabled": true
    }
  }
}